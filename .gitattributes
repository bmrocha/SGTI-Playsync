# Force LF line endings for all text files — prevents CRLF from Windows
# leaking into Docker Linux containers and causing issues.
* text=auto eol=lf

# Binary files should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.db binary
