# =============================================================================
# PlaySync — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha todos os valores marcados com
# "your-..." antes de iniciar o projeto pela primeira vez.
# NUNCA commit o arquivo .env real.
# =============================================================================

# ─── Banco de Dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sgti_playsync?schema=public
POSTGRES_USER=playsync
POSTGRES_PASSWORD=your-secure-db-password
POSTGRES_DB=sgti_playsync
DATABASE_SSL=false
# DATABASE_SSL=true
# DATABASE_SSL_CA_PATH=/caminho/para/ca.pem

# ─── JWT (mínimo 32 caracteres) ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-chars

# ─── Senha inicial do administrador ──────────────────────────────────────────
# Usada apenas na primeira execução do seed. O usuário será forçado a
# alterar esta senha no primeiro login.
ADMIN_INITIAL_PASSWORD=your-secure-admin-password

# ─── URLs ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Administração ─────────────────────────────────────────────────────────────
ALLOW_ADMIN_CREATION=false
BYPASS_2FA_EMAILS=admin@example.com

# ─── Cron / Background ───────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret

# ─── Licenciamento ───────────────────────────────────────────────────────────
LICENSE_ISSUER=SGTI
LICENSE_PUBLIC_KEY=your-base64-public-key

# ─── Sentry (opcional) ───────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ─── Node / Next.js (não defina NODE_ENV em .env em produção) ────────────────
# NEXT_TELEMETRY_DISABLED=1
