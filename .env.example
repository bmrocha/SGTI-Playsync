# === Banco de Dados ===
DATABASE_URL=postgresql://user:password@localhost:5432/sgti_playsync?schema=public
POSTGRES_USER=user
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=sgti_playsync
DATABASE_SSL=false
# DATABASE_SSL=true
# DATABASE_SSL_CA_PATH=/caminho/para/ca.pem

# === JWT ===
JWT_SECRET=your-jwt-secret-at-least-32-chars

# === URLs ===
NEXT_PUBLIC_API_URL=http://localhost:3000

# === Administração ===
ALLOW_ADMIN_CREATION=false
BYPASS_2FA_EMAILS=admin@example.com

# === Cron / Background ===
CRON_SECRET=your-cron-secret

# === Licenciamento ===
LICENSE_ISSUER=SGTI
LICENSE_PUBLIC_KEY=your-base64-public-key

# === Sentry (opcional) ===
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
