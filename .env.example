# ============================================
# PlaySync - Variaveis de Ambiente (Exemplo)
# ============================================
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# ============================================
# Banco de Dados (PostgreSQL)
# ============================================
# Usuario do PostgreSQL
POSTGRES_USER=playsync

# Senha forte - ALTERAR para producao
POSTGRES_PASSWORD=altere_para_senha_segura_aqui

# Nome do banco de dados
POSTGRES_DB=sgti_playsync

# URL de conexao (usada pelo app)
# Em Docker: o host é o nome do service (playsync_db_player)
# Em desenvolvimento local: use localhost:5433
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@playsync_db_player:5432/${POSTGRES_DB}?schema=public

# SSL para banco de dados
# true = exige SSL (recomendado para producao)
# false = sem SSL (apenas desenvolvimento)
DATABASE_SSL=false

# Caminho para certificado CA (opcional, usado quando DATABASE_SSL=true)
# DATABASE_SSL_CA_PATH=/caminho/para/ca.pem

# ============================================
# Autenticacao
# ============================================
# Chave secreta para JWT - GERAR uma nova para producao
# Sugestao: openssl rand -hex 64
JWT_SECRET=altere_para_chave_secreta_longa_e_aleatoria_aqui

# Senha inicial do administrador (usada apenas no primeiro seed)
ADMIN_INITIAL_PASSWORD=MudeEstaSenha123!

# Permitir criacao automatica do admin inicial
# true = apenas no primeiro deploy
# false = desabilitar apos o primeiro setup
ALLOW_ADMIN_CREATION=true

# Emails que podem pular 2FA (separados por virgula)
BYPASS_2FA_EMAILS=admin@sgti.tec.br

# ============================================
# Aplicacao
# ============================================
# URL publica da API (ajuste para o dominio do servidor)
NEXT_PUBLIC_API_URL=http://localhost:3000

# NOTA: NAO defina NODE_ENV em producao.
# O Next.js usa 'production' automaticamente ao rodar 'next start'.

# ============================================
# Cron / Tarefas Agendadas
# ============================================
# Segredo para rotas de cron (protege endpoints agendados)
CRON_SECRET=altere_para_chave_aleatoria_aqui

# ============================================
# Licenca SGTI
# ============================================
# Nome do emissor da licenca
LICENSE_ISSUER=SGTI

# Chave publica para validacao de licenca (base64)
# Gerada pelo sistema SGTI License Manager
LICENSE_PUBLIC_KEY=LS0tLS1CRUdJTiBQVUJMSUMgS0VZLS0tLS0K... (sua chave aqui)

# ============================================
# Monitoramento (Opcional)
# ============================================
# Sentry DSN para error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
