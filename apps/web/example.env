# ============================================
# SGTI PlaySync - Exemplo de Configuracao
# ============================================
# Uso: Copie este arquivo como .env e ajuste:
#   cp example.env .env
#
# OU execute para gerar automaticamente:
#   node scripts/license-manager.cjs generate-keys
#
# O comando generate-keys cria um .env completo
# com chaves e senhas aleatorias seguras.
# ============================================

# ─────────────────────────────────────────────
# Banco de Dados PostgreSQL
# ─────────────────────────────────────────────
# A senha deve ser gerada aleatoriamente.
# O comando generate-keys ja gera uma senha segura.
DATABASE_URL=postgresql://admin:SENHA_AQUI@localhost:5432/sgti_playsync?schema=public

# ─────────────────────────────────────────────
# Seguranca - Sessoes de Usuario
# ─────────────────────────────────────────────
# Chave de 512 bits (64 bytes hex) para JWT.
# Gerar: crypto.randomBytes(64).toString('hex')
JWT_SECRET=coloque_uma_chave_aleatoria_de_512_bits_aqui

# ─────────────────────────────────────────────
# Rede / CORS
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Licenciamento do Sistema
# ─────────────────────────────────────────────
LICENSE_ISSUER=SGTI
# A chave publica RSA deve ser colada no painel
# Config > Licenciamento (recomendado).
# O sistema salva automaticamente no .env.
# Gerar: node scripts/license-manager.cjs generate-keys
# LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ─────────────────────────────────────────────
# Ambiente
# ─────────────────────────────────────────────
# development | production
NODE_ENV=development

# ─────────────────────────────────────────────
# Recursos Adicionais
# ─────────────────────────────────────────────
# Permitir criacao de admin direta (seguro apenas em dev)
# ATENCAO: Em producao, mantenha como false para evitar criacao de contas admin nao autorizadas
ALLOW_ADMIN_CREATION=false

# Emails que ignoram 2FA (separados por virgula)
BYPASS_2FA_EMAILS=admin@sgti.tec.br

# Segredo para endpoints de cron (gerar: openssl rand -hex 32)
# Usado para limpeza automatica de logs de auditoria
CRON_SECRET=

# Politicas de Logs de Auditoria
# Retenção minima: 30 dias, Maxima: 365 dias, Padrao: 180 dias
AUDIT_LOG_RETENTION_DAYS=180

# SSL do banco de dados (true em producao com conexao SSL)
DATABASE_SSL=false

# Sentry DSN para error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
